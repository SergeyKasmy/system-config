#!/bin/sh

MAIN_MONITOR="DP-1"

# if this file exists, then waybar is in fullscreen mode
FS_WAYBAR_PID_PATH="/tmp/.waybar-fullscreen-mode.pid"

while true; do
  CURRENT_WORKSPACE_ID=$(hyprctl monitors -j | jq -r ".[] | select(.name == \"$MAIN_MONITOR\") | .activeWorkspace.id")
  HAS_FULLSCREEN_WINDOW=$(hyprctl workspaces -j | jq -r "map(select(.id == $CURRENT_WORKSPACE_ID) | .hasfullscreen) | any")

  # echo "main display has fullscreen window = $HAS_FULLSCREEN_WINDOW"
  # if [ -e "$MARKER_FILE_PATH" ]; then
  #   MARKER_FILE_EXISTS=true
  # else
  #   MARKER_FILE_EXISTS=false
  # fi
  # echo "marker file exists = $MARKER_FILE_EXISTS"

  if [ "$HAS_FULLSCREEN_WINDOW" = "true" ] && [ ! -e "$FS_WAYBAR_PID_PATH" ]; then
    touch "$FS_WAYBAR_PID_PATH"
    waybar --config "$HOME/.config/waybar/fullscreen-config.jsonc" >/dev/null 2>&1 &
    echo $! > "$FS_WAYBAR_PID_PATH"
  elif [ "$HAS_FULLSCREEN_WINDOW" = "false" ] && [ -e "$FS_WAYBAR_PID_PATH" ]; then
    if [ -s "$FS_WAYBAR_PID_PATH" ]; then
      kill "$(cat $FS_WAYBAR_PID_PATH)"
    fi
    rm "$FS_WAYBAR_PID_PATH"
  fi

  sleep 1s
done
