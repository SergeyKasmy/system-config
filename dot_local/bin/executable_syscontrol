#!/bin/bash

case "$1" in
	shutdown)
		exec poweroff
		;;
	reboot)
		exec reboot
		;;
	logout)
		exec uwsm stop
		;;
	suspend)
		exec systemctl suspend
		;;
	lock)
		exec loginctl lock-session
		;;
	*)
		echo "syscontrol: missing or invalid argument"
		echo "Available commands: shutdown, reboot, logout, suspend, lock"
		exit 1
esac
