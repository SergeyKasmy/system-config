#!/bin/bash

case "$1" in
	shutdown)
		exec poweroff
		;;
	reboot)
		exec reboot
		;;
	"reboot-windows")
		exec sudo reboot-windows
		;;
	logout)
		exec uwsm stop
		;;
	suspend)
		exec systemctl suspend
		;;
	lock)
		exec loginctl lock-session
		;;
	*)
		echo "syscontrol: missing or invalid argument"
		echo "Available commands: shutdown, reboot, reboot-windows, logout, suspend, lock"
		exit 1
esac
