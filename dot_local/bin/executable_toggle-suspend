#!/bin/sh

get_focused_pid() {
  hyprctl activewindow -j | jq '.pid'
}

psignal() {
    pids=$(pstree "$2" -npl | grep -oP '(?<=\()[0-9]+(?=\))')
    kill -s $1 $pids
}

psuspend () {
    psignal STOP "$1"
}

pcont () {
    psignal CONT "$1"
}

pid="$(get_focused_pid)"
state=$(ps -o state= "$pid")
if [ "$state" = "T" ]; then
    pcont "$pid"
else
    psuspend "$pid"
fi
