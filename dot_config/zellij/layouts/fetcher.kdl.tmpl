layout {
	{{ include "dot_config/zellij/layouts/default_container.kdl" }}

	cwd "{{ .chezmoi.homeDir }}/dev/projects/pc/fetcher"

	new_tab_template {
		default_container {
			children
		}
	}

	pane_template name="rust-project" split_direction="vertical" {
		// main editor
		pane command="hx" focus=true
		// sidebar with bacon and an empty terminal
		pane size="35%" stacked=true {
			pane command="bacon" expanded=true
			pane
		}
	}
		

	tab name="fetcher" cwd="{{ .chezmoi.homeDir }}/dev/projects/pc/fetcher/fetcher" {
		default_container {
			rust-project
		}
	}

	tab name="fetcher-{{ .personal.nickname }}" cwd="{{ .chezmoi.homeDir }}/dev/projects/pc/fetcher/fetcher-{{ .personal.nickname }}" {
		default_container {
			rust-project
		}
	}
}
